---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import SearchBar from "../components/SearchBar.astro";
import FilterBar from "../components/FilterBar.astro";
import ToolCard from "../components/ToolCard.astro";
import Newsletter from "../components/Newsletter.astro";
import toolsData from "../data/tools.json";

// Filtrar herramientas activas
const activeToolsList = toolsData.filter((t) => !t.status || t.status === "active");

// 3 tarjetas destacadas usando datos reales del JSON
// 1. Mejor puntuación
const bestScoreTool = [...activeToolsList]
  .sort((a, b) => b.score_total - a.score_total)[0];

// 2. Mejor local/open-source
const bestLocalTool = [...activeToolsList]
  .filter((t) => t.open_source === true || t.local_install === true)
  .sort((a, b) => b.score_total - a.score_total)[0];

// 3. Mejor herramienta para creadores
const bestCreatorTool = [...activeToolsList]
  .sort((a, b) => b.score_creator_potential - a.score_creator_potential)[0];

// Novedades y listados
const topTools = [...activeToolsList]
  .sort((a, b) => b.score_total - a.score_total)
  .slice(0, 6);

const newestTools = [...activeToolsList]
  .sort((a, b) => new Date(b.detected_at).getTime() - new Date(a.detected_at).getTime())
  .slice(0, 6);

const openSourceTools = activeToolsList.filter((t) => t.open_source === true || t.free_type === "Open-source").slice(0, 4);
const freeCreditTools = activeToolsList.filter((t) => t.free_type === "Créditos gratis" || t.free_type === "Trial útil").slice(0, 4);

// Stats dinámicas para el Hero
const totalTools = activeToolsList.length;
const openSourceCount = activeToolsList.filter((t) => t.open_source === true || t.local_install === true).length;
const freeTypes = new Set(activeToolsList.map((t) => t.free_type).filter(Boolean)).size;
---

<BaseLayout title="Free AI Radar - Novedades de IA gratis, filtradas y explicadas">
  <Header />

  <main class="space-y-24">
    <!-- Hero Section -->
    <Hero totalTools={totalTools} openSourceCount={openSourceCount} freeTypes={freeTypes} />

    <!-- Sección: Lo mejor detectado esta semana (Destacados de terminal premium) -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10 text-center lg:text-left">
        <span class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-radar-accent)]">Destacados de la semana</span>
        <h2 class="text-3xl font-extrabold text-[var(--color-radar-text)] mt-1 font-sora">Lo mejor detectado en el radar</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Destacado 1: Mayor puntuación -->
        {bestScoreTool && (
          <div class="p-6 bg-[var(--color-radar-surface)] border border-[var(--color-radar-accent)]/20 rounded-xl relative overflow-hidden flex flex-col justify-between">
            <div class="absolute top-0 right-0 w-24 h-24 bg-[var(--color-radar-accent)]/5 rounded-full translate-x-8 -translate-y-8 blur-lg"></div>
            <div>
              <span class="px-2 py-0.5 text-[9px] font-extrabold uppercase tracking-wider rounded bg-[var(--color-radar-accent)] text-[var(--color-radar-bg)]">Top Score</span>
              <h3 class="text-xl font-bold text-[var(--color-radar-text)] mt-3 mb-2 font-sora">{bestScoreTool.name}</h3>
              <p class="text-xs text-[var(--color-radar-text-muted)] line-clamp-2 leading-relaxed mb-4">{bestScoreTool.description_short}</p>
            </div>
            <div class="flex items-center justify-between pt-4 border-t border-[var(--color-radar-border)]">
              <span class="text-xs font-bold text-[var(--color-radar-accent)]">{bestScoreTool.score_total}/100 Score</span>
              <a href={`/tools/${bestScoreTool.slug}`} class="text-xs font-bold uppercase tracking-wider text-[var(--color-radar-text)] hover:text-[var(--color-radar-accent)] transition-colors">Ver ficha &rarr;</a>
            </div>
          </div>
        )}

        <!-- Destacado 2: Mejor Local / Open-Source -->
        {bestLocalTool && (
          <div class="p-6 bg-[var(--color-radar-surface)] border border-[var(--color-radar-secondary)]/20 rounded-xl relative overflow-hidden flex flex-col justify-between">
            <div class="absolute top-0 right-0 w-24 h-24 bg-[var(--color-radar-secondary)]/5 rounded-full translate-x-8 -translate-y-8 blur-lg"></div>
            <div>
              <span class="px-2 py-0.5 text-[9px] font-extrabold uppercase tracking-wider rounded bg-[var(--color-radar-secondary)] text-[var(--color-radar-bg)]">Local & Open Source</span>
              <h3 class="text-xl font-bold text-[var(--color-radar-text)] mt-3 mb-2 font-sora">{bestLocalTool.name}</h3>
              <p class="text-xs text-[var(--color-radar-text-muted)] line-clamp-2 leading-relaxed mb-4">{bestLocalTool.description_short}</p>
            </div>
            <div class="flex items-center justify-between pt-4 border-t border-[var(--color-radar-border)]">
              <span class="text-xs font-bold text-[var(--color-radar-secondary)]">{bestLocalTool.score_total}/100 Score</span>
              <a href={`/tools/${bestLocalTool.slug}`} class="text-xs font-bold uppercase tracking-wider text-[var(--color-radar-text)] hover:text-[var(--color-radar-secondary)] transition-colors">Ver ficha &rarr;</a>
            </div>
          </div>
        )}

        <!-- Destacado 3: Potencial Creadores -->
        {bestCreatorTool && (
          <div class="p-6 bg-[var(--color-radar-surface)] border border-[var(--color-radar-border)] rounded-xl relative overflow-hidden flex flex-col justify-between">
            <div class="absolute top-0 right-0 w-24 h-24 bg-white/5 rounded-full translate-x-8 -translate-y-8 blur-lg"></div>
            <div>
              <span class="px-2 py-0.5 text-[9px] font-extrabold uppercase tracking-wider rounded bg-[var(--color-radar-surface)] text-[var(--color-radar-text-muted)] border border-[var(--color-radar-border)]">Ideal Creadores</span>
              <h3 class="text-xl font-bold text-[var(--color-radar-text)] mt-3 mb-2 font-sora">{bestCreatorTool.name}</h3>
              <p class="text-xs text-[var(--color-radar-text-muted)] line-clamp-2 leading-relaxed mb-4">{bestCreatorTool.description_short}</p>
            </div>
            <div class="flex items-center justify-between pt-4 border-t border-[var(--color-radar-border)]">
              <span class="text-xs font-bold text-[var(--color-radar-text)]">Potencial: {bestCreatorTool.score_creator_potential}/10</span>
              <a href={`/tools/${bestCreatorTool.slug}`} class="text-xs font-bold uppercase tracking-wider text-[var(--color-radar-text)] hover:text-[var(--color-radar-accent)] transition-colors">Ver ficha &rarr;</a>
            </div>
          </div>
        )}
      </div>
    </section>

    <!-- Search + Filters Section -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="border border-[var(--color-radar-border)] rounded-xl bg-[var(--color-radar-surface)] p-6 md:p-8">
        <div class="flex flex-col md:flex-row gap-6 items-start justify-between mb-8">
          <div>
            <span class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-radar-accent)]">Buscador inteligente</span>
            <h2 class="text-2xl font-extrabold text-[var(--color-radar-text)] mt-0.5 font-sora">Explora el radar</h2>
            <p class="text-xs text-[var(--color-radar-text-muted)] mt-1">Busca por nombre o filtra por categoría y gratuidad para encontrar la herramienta idónea.</p>
          </div>
          <SearchBar />
        </div>
        <FilterBar />
      </div>
    </section>

    <!-- Top novedades gratis -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between mb-8 gap-4">
        <div>
          <span class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-radar-accent)]">Clasificación general</span>
          <h2 class="text-2xl font-extrabold text-[var(--color-radar-text)] mt-0.5 font-sora">Top herramientas del radar</h2>
        </div>
        <a href="/tools?sort=score" class="text-xs font-bold uppercase tracking-wider text-[var(--color-radar-accent)] hover:text-[var(--color-radar-accent)]/80 transition-colors">Ver listado completo &rarr;</a>
      </div>
      <div id="tools-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {topTools.map((tool) => <ToolCard tool={tool} />)}
      </div>
    </section>

    <!-- Nuevas herramientas detectadas -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between mb-8 gap-4">
        <div>
          <span class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-radar-secondary)]">Últimos hallazgos</span>
          <h2 class="text-2xl font-extrabold text-[var(--color-radar-text)] mt-0.5 font-sora">Novedades recientes</h2>
        </div>
        <a href="/tools?sort=newest" class="text-xs font-bold uppercase tracking-wider text-[var(--color-radar-secondary)] hover:text-[var(--color-radar-secondary)]/80 transition-colors">Ver novedades &rarr;</a>
      </div>
      <div id="tools-grid-new" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {newestTools.map((tool) => <ToolCard tool={tool} />)}
      </div>
    </section>

    <!-- Gratis real vs Humo (Rediseño de terminal premium) -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-radar-accent)]">Metodología de curación</span>
        <h2 class="text-3xl font-extrabold text-[var(--color-radar-text)] mt-1 font-sora">Gratis de verdad frente al humo</h2>
        <p class="text-sm text-[var(--color-radar-text-muted)] max-w-xl mx-auto mt-2 leading-relaxed">
          No todo lo que se etiqueta como "gratis" lo es. Clasificamos las herramientas de forma rigurosa y transparente.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
        <div class="p-5 rounded-xl bg-[var(--color-radar-surface)] border border-[var(--color-radar-border)] hover:border-[var(--color-radar-accent)]/20 transition-all duration-300">
          <div class="w-1.5 h-1.5 rounded-full bg-[#74F7C0] mb-3"></div>
          <h3 class="font-bold text-[var(--color-radar-text)] text-xs uppercase tracking-wider mb-2 font-sora">Gratis real</h3>
          <p class="text-[11px] text-[var(--color-radar-text-muted)] leading-relaxed">Usable sin pagar de forma continua. Sin trampas ocultas.</p>
        </div>
        <div class="p-5 rounded-xl bg-[var(--color-radar-surface)] border border-[var(--color-radar-border)] hover:border-[var(--color-radar-accent)]/20 transition-all duration-300">
          <div class="w-1.5 h-1.5 rounded-full bg-[#74F7C0]/60 mb-3"></div>
          <h3 class="font-bold text-[var(--color-radar-text)] text-xs uppercase tracking-wider mb-2 font-sora">Freemium decente</h3>
          <p class="text-[11px] text-[var(--color-radar-text-muted)] leading-relaxed">Límites gratuitos reales y útiles para proyectos básicos.</p>
        </div>
        <div class="p-5 rounded-xl bg-[var(--color-radar-surface)] border border-[var(--color-radar-border)] hover:border-[var(--color-radar-accent)]/20 transition-all duration-300">
          <div class="w-1.5 h-1.5 rounded-full bg-[var(--color-radar-secondary)] mb-3"></div>
          <h3 class="font-bold text-[var(--color-radar-text)] text-xs uppercase tracking-wider mb-2 font-sora">Créditos gratis</h3>
          <p class="text-[11px] text-[var(--color-radar-text-muted)] leading-relaxed">Saldo inicial o créditos periódicos suficientes para pruebas reales.</p>
        </div>
        <div class="p-5 rounded-xl bg-[var(--color-radar-surface)] border border-[var(--color-radar-border)] hover:border-[var(--color-radar-accent)]/20 transition-all duration-300">
          <div class="w-1.5 h-1.5 rounded-full bg-[var(--color-radar-yellow)] mb-3"></div>
          <h3 class="font-bold text-[var(--color-radar-text)] text-xs uppercase tracking-wider mb-2 font-sora">Trial limitado</h3>
          <p class="text-[11px] text-[var(--color-radar-text-muted)] leading-relaxed">Caduca rápidamente, requiere introducir tarjeta o restringe en exceso.</p>
        </div>
        <div class="p-5 rounded-xl bg-[var(--color-radar-surface)] border border-[var(--color-radar-border)] hover:border-[var(--color-radar-accent)]/20 transition-all duration-300">
          <div class="w-1.5 h-1.5 rounded-full bg-[var(--color-radar-red)] mb-3"></div>
          <h3 class="font-bold text-[var(--color-radar-text)] text-xs uppercase tracking-wider mb-2 font-sora">Humo probable</h3>
          <p class="text-[11px] text-[var(--color-radar-text-muted)] leading-relaxed">Publicidad engañosa, límites confusos y poca transparencia.</p>
        </div>
      </div>
    </section>

    <!-- Grid: Open-source + Créditos gratis (Fila premium) -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Modelos open-source -->
        <div>
          <div class="flex items-center justify-between mb-6 pb-2 border-b border-[var(--color-radar-border)]">
            <h2 class="text-lg font-bold text-[var(--color-radar-text)] font-sora uppercase tracking-wider">Modelos open-source</h2>
            <a href="/tools?free_type=Open-source" class="text-xs font-bold text-[var(--color-radar-accent)] hover:underline">Ver todos &rarr;</a>
          </div>
          <div class="space-y-3">
            {openSourceTools.map((tool) => (
              <a href={`/tools/${tool.slug}`} class="block bg-[var(--color-radar-surface)] border border-[var(--color-radar-border)] rounded-lg p-4 hover:border-[var(--color-radar-accent)]/20 hover:bg-[#131B26] transition-all">
                <div class="flex items-center justify-between">
                  <div>
                    <h3 class="font-bold text-[var(--color-radar-text)] text-xs uppercase tracking-wider font-sora">{tool.name}</h3>
                    <p class="text-xs text-[var(--color-radar-text-muted)] mt-1 line-clamp-1">{tool.description_short}</p>
                  </div>
                  <span class="text-xs font-bold font-sora text-[var(--color-radar-accent)] bg-[var(--color-radar-accent)]/10 px-2 py-1 rounded">{tool.score_total}</span>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Créditos gratis / trials útiles -->
        <div>
          <div class="flex items-center justify-between mb-6 pb-2 border-b border-[var(--color-radar-border)]">
            <h2 class="text-lg font-bold text-[var(--color-radar-text)] font-sora uppercase tracking-wider">Créditos y trials</h2>
            <a href="/tools?free_type=Créditos%20gratis" class="text-xs font-bold text-[var(--color-radar-secondary)] hover:underline">Ver todos &rarr;</a>
          </div>
          <div class="space-y-3">
            {freeCreditTools.map((tool) => (
              <a href={`/tools/${tool.slug}`} class="block bg-[var(--color-radar-surface)] border border-[var(--color-radar-border)] rounded-lg p-4 hover:border-[var(--color-radar-secondary)]/20 hover:bg-[#131B26] transition-all">
                <div class="flex items-center justify-between">
                  <div>
                    <h3 class="font-bold text-[var(--color-radar-text)] text-xs uppercase tracking-wider font-sora">{tool.name}</h3>
                    <p class="text-xs text-[var(--color-radar-text-muted)] mt-1 line-clamp-1">{tool.description_short}</p>
                  </div>
                  <span class="text-xs font-bold font-sora text-[var(--color-radar-secondary)] bg-[var(--color-radar-secondary)]/10 px-2 py-1 rounded">{tool.score_total}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ComfyUI sin GPU Callout (Radar editorial premium) -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-[var(--color-radar-surface)] border border-[var(--color-radar-border)] rounded-xl p-8 md:p-12 max-w-5xl mx-auto flex flex-col md:flex-row items-center justify-between gap-8 relative overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(116,247,192,0.02),transparent_45%)]"></div>
        <div class="space-y-4 relative z-10 max-w-2xl">
          <span class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-radar-accent)]">Ejecución en la nube</span>
          <h2 class="text-2xl md:text-3xl font-extrabold text-[var(--color-radar-text)] font-sora tracking-tight">
            ¿Quieres usar ComfyUI sin gráfica?
          </h2>
          <p class="text-xs sm:text-sm text-[var(--color-radar-text-muted)] leading-relaxed">
            Compara servicios cloud, créditos gratuitos y opciones para ejecutar workflows desde el navegador. Evita invertir en hardware costoso.
          </p>
        </div>
        <div class="relative z-10 flex-shrink-0 self-start md:self-auto">
          <a
            href="/comfyui-sin-gpu"
            class="px-6 py-3.5 bg-[var(--color-radar-accent)] hover:bg-[var(--color-radar-accent)]/80 text-[var(--color-radar-bg)] font-bold text-xs uppercase tracking-wider rounded-lg transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-radar-accent)]"
          >
            Ver ComfyUI sin GPU &rarr;
          </a>
        </div>
      </div>
    </section>

    <!-- PWA Install (Diseño de terminal de producto SaaS) -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-[var(--color-radar-surface)] border border-[var(--color-radar-border)] rounded-xl p-8 md:p-12 max-w-5xl mx-auto">
        <div class="flex flex-col lg:flex-row gap-12 items-center">
          <div class="flex-1">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded bg-[var(--color-radar-border)] text-[9px] font-bold uppercase tracking-widest text-[var(--color-radar-accent)] mb-4">
              PWA Instalable
            </div>
            <h2 class="text-2xl sm:text-3xl font-extrabold text-[var(--color-radar-text)] mb-3 font-sora">Lleva el radar en tu dispositivo móvil</h2>
            <p class="text-xs sm:text-sm text-[var(--color-radar-text-muted)] mb-8 leading-relaxed">
              Instala Free AI Radar en tu pantalla de inicio para consultar novedades sobre IA de forma instantánea. Sin pasar por tiendas de aplicaciones.
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="p-4 rounded-lg bg-[var(--color-radar-bg)] border border-[var(--color-radar-border)]">
                <span class="text-xs font-bold text-[var(--color-radar-accent)] uppercase tracking-wider font-sora">Android (Chrome)</span>
                <ol class="text-xs text-[var(--color-radar-text-muted)] mt-2 space-y-1">
                  <li>1. Abre el menú ⋮</li>
                  <li>2. Toca "Instalar aplicación"</li>
                  <li>3. Confirma la instalación</li>
                </ol>
              </div>
              <div class="p-4 rounded-lg bg-[var(--color-radar-bg)] border border-[var(--color-radar-border)]">
                <span class="text-xs font-bold text-[var(--color-radar-secondary)] uppercase tracking-wider font-sora">iPhone (Safari)</span>
                <ol class="text-xs text-[var(--color-radar-text-muted)] mt-2 space-y-1">
                  <li>1. Toca el botón Compartir 📤</li>
                  <li>2. Toca "Añadir a pantalla de inicio"</li>
                  <li>3. Confirma la acción</li>
                </ol>
              </div>
            </div>
          </div>
          <div class="flex-shrink-0 hidden lg:block">
            <div class="w-36 h-36 rounded-xl bg-[#131B26] border border-[var(--color-radar-border)] flex items-center justify-center shadow-2xl relative group">
              <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-radar-accent)]/5 to-transparent rounded-xl"></div>
              <span class="text-4xl text-[var(--color-radar-accent)] transition-transform duration-500 group-hover:scale-110">📡</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Newsletter -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
      <Newsletter />
    </section>
  </main>

  <Footer />
</BaseLayout>
