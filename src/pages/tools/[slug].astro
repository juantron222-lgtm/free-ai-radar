---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ScoreBadge from "../../components/ScoreBadge.astro";
import VerdictTag from "../../components/VerdictTag.astro";
import CategoryBadge from "../../components/CategoryBadge.astro";
import FreeTypeBadge from "../../components/FreeTypeBadge.astro";
import toolsData from "../../data/tools.json";

export function getStaticPaths() {
  return toolsData.map((tool) => ({
    params: { slug: tool.slug },
  }));
}

const { slug } = Astro.params;
const tool = toolsData.find((t) => t.slug === slug);

if (!tool) {
  return Astro.redirect("/tools");
}

const formatDate = (d: string) =>
  new Date(d).toLocaleDateString("es-ES", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });

const boolIcon = (val: boolean | string) => {
  if (val === true) return "✅";
  if (val === false) return "❌";
  return "⚠️ No confirmado";
};

const boolLabel = (val: boolean | string, trueLabel: string, falseLabel: string) => {
  if (val === true) return trueLabel;
  if (val === false) return falseLabel;
  return "No confirmado";
};
const seoTitle = `${tool.name}: ${tool.description_short.split('.')[0]}`;
---

<BaseLayout title={seoTitle} description={tool.description_short}>
  <Header />

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <!-- Back link -->
    <a href="/tools" class="inline-flex items-center gap-1 text-sm text-[var(--color-radar-text-muted)] hover:text-[var(--color-radar-accent-glow)] transition-colors mb-6">
      &larr; Volver al listado
    </a>

    <!-- Header -->
    <div class="mb-8">
      <div class="flex flex-wrap items-center gap-3 mb-3">
        <CategoryBadge category={tool.category} />
        <FreeTypeBadge freeType={tool.free_type} />
        {tool.open_source === true && (
          <span class="px-2.5 py-1 text-xs font-medium rounded-full border bg-blue-500/10 text-blue-400 border-blue-500/20">Open-source</span>
        )}
      </div>

      <h1 class="text-3xl md:text-4xl font-extrabold text-[var(--color-radar-text)] mb-5">{tool.name}</h1>

      <!-- INFO DE GRATUIDAD ARRIBA DEL TODO -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-5">
        <div class="p-3 rounded-xl bg-[var(--color-radar-card)] border border-[var(--color-radar-border)]">
          <span class="text-[10px] uppercase tracking-wider text-[var(--color-radar-text-muted)]">Tipo</span>
          <p class="text-sm font-bold text-[var(--color-radar-text)]">{tool.free_type}</p>
        </div>
        <div class="p-3 rounded-xl bg-[var(--color-radar-card)] border border-[var(--color-radar-border)]">
          <span class="text-[10px] uppercase tracking-wider text-[var(--color-radar-text-muted)]">Gratis de verdad</span>
          <p class="text-sm font-bold text-[var(--color-radar-text)]">
            {tool.free_type === "Gratis real" || tool.free_type === "Open-source" || tool.free_type === "Local" ? "✅ Sí" : tool.free_type === "Humo probable" ? "❌ No" : "⚠️ Parcial"}
          </p>
        </div>
        <div class="p-3 rounded-xl bg-[var(--color-radar-card)] border border-[var(--color-radar-border)]">
          <span class="text-[10px] uppercase tracking-wider text-[var(--color-radar-text-muted)]">Tarjeta</span>
          <p class={`text-sm font-bold ${tool.requires_credit_card === true ? 'text-red-400' : tool.requires_credit_card === false ? 'text-green-400' : 'text-yellow-400'}`}>
            {tool.requires_credit_card === true ? "💳 Sí" : tool.requires_credit_card === false ? "✅ No" : "⚠️ No confirmado"}
          </p>
        </div>
        <div class="p-3 rounded-xl bg-[var(--color-radar-card)] border border-[var(--color-radar-border)]">
          <span class="text-[10px] uppercase tracking-wider text-[var(--color-radar-text-muted)]">Registro</span>
          <p class={`text-sm font-bold ${tool.requires_signup === false ? 'text-green-400' : 'text-[var(--color-radar-text)]'}`}>
            {tool.requires_signup === true ? "Sí" : tool.requires_signup === false ? "✅ No" : "⚠️ No confirmado"}
          </p>
        </div>
      </div>

      <!-- Score + Veredicto -->
      <div class="flex flex-col sm:flex-row sm:items-center gap-4 mb-4 bg-[var(--color-radar-card)] border border-[var(--color-radar-border)] rounded-2xl p-5">
        <ScoreBadge score={tool.score_total} label="Puntuación total" size="lg" />
        <div class="flex-1">
          <VerdictTag verdict={tool.verdict} riskLevel={tool.risk_level} />
        </div>
        <div class="text-xs text-[var(--color-radar-text-muted)]">
          <p>Detectado: {formatDate(tool.detected_at)}</p>
          <p>Revisado: {formatDate(tool.last_checked_at)}</p>
        </div>
      </div>

      <!-- Marca de agua + Uso comercial -->
      <div class="flex flex-wrap gap-3 mb-4">
        <span class={`px-3 py-1.5 text-xs font-medium rounded-lg border ${tool.has_watermark === false ? 'bg-green-500/10 text-green-400 border-green-500/20' : tool.has_watermark === true ? 'bg-red-500/10 text-red-400 border-red-500/20' : 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20'}`}>
          Marca de agua: {tool.has_watermark === true ? "Sí" : tool.has_watermark === false ? "No" : "No confirmado"}
        </span>
        <span class={`px-3 py-1.5 text-xs font-medium rounded-lg border ${tool.commercial_use === true ? 'bg-green-500/10 text-green-400 border-green-500/20' : tool.commercial_use === false ? 'bg-red-500/10 text-red-400 border-red-500/20' : 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20'}`}>
          Uso comercial: {tool.commercial_use === true ? "✅ Sí" : tool.commercial_use === "parcial" ? "⚠️ Parcial" : tool.commercial_use === false ? "❌ No" : "No confirmado"}
        </span>
        <span class={`px-3 py-1.5 text-xs font-medium rounded-lg border ${tool.local_install === true ? 'bg-blue-500/10 text-blue-400 border-blue-500/20' : 'bg-[var(--color-radar-surface)] text-[var(--color-radar-text-muted)] border-[var(--color-radar-border)]'}`}>
          Instalación local: {tool.local_install === true ? "✅ Sí" : tool.local_install === false ? "No" : "No confirmado"}
        </span>
      </div>

      <!-- Novedad detectada -->
      {tool.novelty_summary && (
        <div class="p-4 rounded-xl bg-[var(--color-radar-accent)]/5 border border-[var(--color-radar-accent)]/20">
          <span class="text-xs font-semibold text-[var(--color-radar-accent-glow)] uppercase tracking-wide">Novedad detectada</span>
          <p class="text-sm text-[var(--color-radar-text)] mt-1">{tool.novelty_summary}</p>
        </div>
      )}
    </div>

    <!-- Main content grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Left: main content -->
      <div class="lg:col-span-2 space-y-8">
        <!-- Description -->
        <section>
          <h2 class="text-lg font-bold text-[var(--color-radar-text)] mb-3">📋 Descripción</h2>
          <p class="text-[var(--color-radar-text-muted)] leading-relaxed">{tool.description_long || tool.description_short}</p>
        </section>

        <!-- Plan gratuito -->
        <section>
          <h2 class="text-lg font-bold text-[var(--color-radar-text)] mb-3">🆓 Plan gratuito</h2>
          <div class="p-4 rounded-xl bg-[var(--color-radar-card)] border border-[var(--color-radar-border)]">
            <p class="text-sm text-[var(--color-radar-text)]">{tool.free_plan_summary}</p>
          </div>
        </section>

        <!-- Sirve para / No sirve para -->
        <section class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <h3 class="text-sm font-bold text-green-400 mb-2">✅ Sirve para</h3>
            <ul class="space-y-1">
              {tool.use_cases?.map((uc: string) => (
                <li class="text-sm text-[var(--color-radar-text-muted)] flex items-start gap-2">
                  <span class="text-green-400 mt-0.5">•</span> {uc}
                </li>
              ))}
            </ul>
          </div>
          <div>
            <h3 class="text-sm font-bold text-red-400 mb-2">❌ No sirve para</h3>
            <ul class="space-y-1">
              {tool.limitations?.map((lim: string) => (
                <li class="text-sm text-[var(--color-radar-text-muted)] flex items-start gap-2">
                  <span class="text-red-400 mt-0.5">•</span> {lim}
                </li>
              ))}
            </ul>
          </div>
        </section>

        <!-- Alternativas -->
        {tool.alternatives && tool.alternatives.length > 0 && (
          <section>
            <h2 class="text-lg font-bold text-[var(--color-radar-text)] mb-3">🔄 Alternativas</h2>
            <div class="flex flex-wrap gap-2">
              {tool.alternatives.map((alt: string) => (
                <span class="px-3 py-1.5 text-sm rounded-lg bg-[var(--color-radar-card)] border border-[var(--color-radar-border)] text-[var(--color-radar-text-muted)]">{alt}</span>
              ))}
            </div>
          </section>
        )}
      </div>

      <!-- Right: sidebar -->
      <aside class="space-y-6">
        <!-- Puntuaciones detalladas -->
        <div class="p-5 rounded-2xl bg-[var(--color-radar-card)] border border-[var(--color-radar-border)]">
          <h3 class="font-bold text-[var(--color-radar-text)] mb-4">📊 Puntuaciones</h3>
          <div class="space-y-3">
            <div>
              <div class="flex justify-between text-sm mb-1">
                <span class="text-[var(--color-radar-text-muted)]">Gratis real</span>
                <span class="text-[var(--color-radar-text)] font-medium">{tool.score_free_real}/10</span>
              </div>
              <div class="h-1.5 rounded-full bg-[var(--color-radar-bg)]">
                <div class="h-full rounded-full bg-green-500" style={`width: ${tool.score_free_real * 10}%`}></div>
              </div>
            </div>
            <div>
              <div class="flex justify-between text-sm mb-1">
                <span class="text-[var(--color-radar-text-muted)]">Utilidad</span>
                <span class="text-[var(--color-radar-text)] font-medium">{tool.score_usefulness}/10</span>
              </div>
              <div class="h-1.5 rounded-full bg-[var(--color-radar-bg)]">
                <div class="h-full rounded-full bg-blue-500" style={`width: ${tool.score_usefulness * 10}%`}></div>
              </div>
            </div>
            <div>
              <div class="flex justify-between text-sm mb-1">
                <span class="text-[var(--color-radar-text-muted)]">Facilidad</span>
                <span class="text-[var(--color-radar-text)] font-medium">{tool.score_ease}/10</span>
              </div>
              <div class="h-1.5 rounded-full bg-[var(--color-radar-bg)]">
                <div class="h-full rounded-full bg-yellow-500" style={`width: ${tool.score_ease * 10}%`}></div>
              </div>
            </div>
            <div>
              <div class="flex justify-between text-sm mb-1">
                <span class="text-[var(--color-radar-text-muted)]">Potencial creadores</span>
                <span class="text-[var(--color-radar-text)] font-medium">{tool.score_creator_potential}/10</span>
              </div>
              <div class="h-1.5 rounded-full bg-[var(--color-radar-bg)]">
                <div class="h-full rounded-full bg-purple-500" style={`width: ${tool.score_creator_potential * 10}%`}></div>
              </div>
            </div>
            <div>
              <div class="flex justify-between text-sm mb-1">
                <span class="text-[var(--color-radar-text-muted)]">Transparencia</span>
                <span class="text-[var(--color-radar-text)] font-medium">{tool.score_transparency}/10</span>
              </div>
              <div class="h-1.5 rounded-full bg-[var(--color-radar-bg)]">
                <div class="h-full rounded-full bg-cyan-500" style={`width: ${tool.score_transparency * 10}%`}></div>
              </div>
            </div>
          </div>
          <div class="mt-4 pt-3 border-t border-[var(--color-radar-border)]">
            <div class="flex justify-between">
              <span class="text-sm text-[var(--color-radar-text-muted)]">Riesgo de humo</span>
              <span class={`text-sm font-bold ${
                tool.risk_level === "bajo" ? "text-green-400" :
                tool.risk_level === "medio" ? "text-yellow-400" : "text-red-400"
              }`}>
                {tool.risk_level === "bajo" ? "🟢 Bajo" : tool.risk_level === "medio" ? "🟡 Medio" : "🔴 Alto"}
              </span>
            </div>
          </div>
        </div>

        <!-- Enlaces -->
        <div class="p-5 rounded-2xl bg-[var(--color-radar-card)] border border-[var(--color-radar-border)]">
          <h3 class="font-bold text-[var(--color-radar-text)] mb-4">🔗 Enlaces</h3>
          <div class="space-y-2">
            {tool.official_url && (
              <a href={tool.official_url} target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-2 text-sm text-[var(--color-radar-accent-glow)] hover:underline">
                🌐 Web oficial &rarr;
              </a>
            )}
            {tool.github_url && (
              <a href={tool.github_url} target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-2 text-sm text-[var(--color-radar-text-muted)] hover:text-[var(--color-radar-text)]">
                📦 GitHub &rarr;
              </a>
            )}
            {tool.pricing_url && (
              <a href={tool.pricing_url} target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-2 text-sm text-[var(--color-radar-text-muted)] hover:text-[var(--color-radar-text)]">
                💰 Pricing &rarr;
              </a>
            )}
            {tool.docs_url && (
              <a href={tool.docs_url} target="_blank" rel="noopener noreferrer"
                class="flex items-center gap-2 text-sm text-[var(--color-radar-text-muted)] hover:text-[var(--color-radar-text)]">
                📖 Documentación &rarr;
              </a>
            )}
          </div>
        </div>

        <!-- Tags -->
        <div class="p-5 rounded-2xl bg-[var(--color-radar-card)] border border-[var(--color-radar-border)]">
          <h3 class="font-bold text-[var(--color-radar-text)] mb-3">🏷️ Etiquetas</h3>
          <div class="flex flex-wrap gap-1.5">
            {tool.tags?.map((tag: string) => (
              <span class="px-2.5 py-1 text-xs font-medium rounded-lg bg-[var(--color-radar-surface)] text-[var(--color-radar-text-muted)] border border-[var(--color-radar-border)]">
                {tag}
              </span>
            ))}
          </div>
        </div>

        <!-- Fuentes -->
        {tool.source_urls && tool.source_urls.length > 0 && (
          <div class="p-5 rounded-2xl bg-[var(--color-radar-card)] border border-[var(--color-radar-border)]">
            <h3 class="font-bold text-[var(--color-radar-text)] mb-3">📚 Fuentes</h3>
            <ul class="space-y-1">
              {tool.source_urls.map((url: string) => (
                <li>
                  <a href={url} target="_blank" rel="noopener noreferrer"
                    class="text-xs text-[var(--color-radar-text-muted)] hover:text-[var(--color-radar-accent-glow)] break-all">
                    {url}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </aside>
    </div>
  </main>

  <Footer />
</BaseLayout>
