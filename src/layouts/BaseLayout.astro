---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
  ogImage?: string;
  ogType?: string;
}

const {
  title,
  description = "Novedades de IA gratis, filtradas y explicadas.",
  canonicalURL,
  ogImage,
  ogType = "website",
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://free-ai-radar-git-main-nada-de-pro.vercel.app";
const pageTitle = title.includes("Free AI Radar") ? title : `${title} | Free AI Radar`;
const resolvedCanonical = canonicalURL ?? `${siteUrl}${Astro.url.pathname}`;
const resolvedOgImage = ogImage
  ? (ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`)
  : `${siteUrl}/og-default.jpg`;
const siteName = "Free AI Radar";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0f" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Free AI Radar" />

    <!-- Canonical -->
    <link rel="canonical" href={resolvedCanonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- Icons & Manifest -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />


    <title>{pageTitle}</title>
  </head>
  <body class="bg-[var(--color-radar-bg)] text-[var(--color-radar-text)] min-h-screen">
    <slot />
    <script>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register("/sw.js").catch((error) => {
            console.warn("Service Worker registration failed:", error);
          });
        });
      }
    </script>
  </body>
</html>
