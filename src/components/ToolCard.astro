---
import { getScoreColor, getScoreBgColor } from "../lib/scoring";

interface Props {
  tool: {
    slug: string;
    name: string;
    category: string;
    subcategory: string;
    free_type: string;
    description_short: string;
    verdict: string;
    score_total: number;
    detected_at: string;
    last_checked_at: string;
    tags: string[];
    risk_level: string;
    open_source?: boolean | string;
    requires_credit_card?: boolean | string;
    requires_signup?: boolean | string;
  };
}

const { tool } = Astro.props;

// Iconos monocromáticos en formato SVG para cada categoría de IA
const categoryIcons: Record<string, string> = {
  "Imagen IA": `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" class="w-3.5 h-3.5 shrink-0"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`,
  "Vídeo IA": `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" class="w-3.5 h-3.5 shrink-0"><path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>`,
  "Voz IA": `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" class="w-3.5 h-3.5 shrink-0"><path d="M12 1v11M19 8v2a7 7 0 0 1-14 0V8"/><line x1="12" y1="19" x2="12" y2="23"/></svg>`,
  "Música IA": `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" class="w-3.5 h-3.5 shrink-0"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`,
  "Código": `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" class="w-3.5 h-3.5 shrink-0"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  "Modelos open-source": `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" class="w-3.5 h-3.5 shrink-0"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/></svg>`,
  "Herramientas locales": `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" class="w-3.5 h-3.5 shrink-0"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
  "default": `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" class="w-3.5 h-3.5 shrink-0"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>`
};

const dateStr = tool.last_checked_at
  ? new Date(tool.last_checked_at).toLocaleDateString("es-ES", {
      year: "numeric",
      month: "short",
    })
  : "";

const scoreColor = getScoreColor(tool.score_total);

// Datos secundarios clave (máximo 3)
const secondaryData = [];
if (tool.open_source === true) {
  secondaryData.push("Código abierto");
} else if (tool.requires_signup === false) {
  secondaryData.push("Sin registro");
} else {
  secondaryData.push("SaaS Cloud");
}

if (tool.requires_credit_card === false) {
  secondaryData.push("Sin tarjeta");
} else if (tool.requires_credit_card === true) {
  secondaryData.push("Requiere tarjeta");
}

if (tool.free_type) {
  secondaryData.push(tool.free_type);
}

const riskBorderColors: Record<string, string> = {
  bajo: "border-l-[3px] border-l-[#74F7C0]",
  medio: "border-l-[3px] border-l-[#F2C66D]",
  alto: "border-l-[3px] border-l-[#FF7B8F]"
};
---

<div
  class="relative group bg-[var(--color-radar-surface)] border border-[var(--color-radar-border)] rounded-xl p-6 transition-all duration-300 hover:bg-[#131B26] hover:border-[var(--color-radar-accent)]/20 hover:shadow-xl hover:shadow-black/20"
  data-tool-card
  data-name={tool.name}
  data-desc={tool.description_short}
  data-category={tool.category}
  data-free-type={tool.free_type}
  data-score={String(tool.score_total)}
  data-date={tool.detected_at}
  data-risk={tool.risk_level}
  data-creator={String(tool.score_creator_potential || 0)}
  data-card={String(tool.requires_credit_card === true)}
>
  <!-- Cabecera de tarjeta: Categoría (Icono + Texto) -->
  <div class="flex items-center justify-between gap-4 mb-4">
    <div class="flex items-center gap-2 text-[var(--color-radar-text-muted)]">
      <span class="text-[var(--color-radar-text-muted)] group-hover:text-[var(--color-radar-accent)] transition-colors" set:html={categoryIcons[tool.category] || categoryIcons.default}></span>
      <span class="text-[10px] font-bold uppercase tracking-widest">{tool.category}</span>
    </div>
    <!-- Puntuación sutil y tipografía Sora -->
    <div class="flex items-center gap-1.5">
      <span class={`text-sm font-extrabold font-sora ${scoreColor}`}>
        {tool.score_total}
      </span>
      <span class="text-[9px] text-[var(--color-radar-text-muted)] font-semibold uppercase tracking-wider">Score</span>
    </div>
  </div>

  <!-- Nombre de la herramienta -->
  <h3 class="text-lg font-bold text-[var(--color-radar-text)] group-hover:text-[var(--color-radar-accent)] transition-colors tracking-tight mb-2">
    <a
      href={`/tools/${tool.slug}`}
      class="after:absolute after:inset-0 after:rounded-xl focus-visible:outline-none focus-visible:after:ring-2 focus-visible:after:ring-[var(--color-radar-accent)] focus-visible:after:ring-offset-2 focus-visible:after:ring-offset-[var(--color-radar-surface)]"
    >
      {tool.name}
    </a>
  </h3>

  <!-- Descripción corta (Máximo 2 líneas) -->
  <p class="text-xs text-[var(--color-radar-text-muted)] line-clamp-2 leading-relaxed mb-4">
    {tool.description_short}
  </p>

  <!-- Veredicto del radar editorial -->
  <div class={`p-3 bg-[var(--color-radar-bg)] rounded-lg text-xs ${riskBorderColors[tool.risk_level] || 'border-l-[3px] border-l-[var(--color-radar-border)]'} mb-4`}>
    <p class="text-[var(--color-radar-text)] italic font-medium line-clamp-2 opacity-90">&ldquo;{tool.verdict}&rdquo;</p>
  </div>

  <!-- Datos Secundarios Clave (badges sutiles monocolor) -->
  <div class="flex flex-wrap gap-2 mb-4">
    {secondaryData.map((data) => (
      <span class="px-2 py-0.5 text-[9px] font-bold uppercase tracking-wider rounded bg-[#131B26] text-[var(--color-radar-text-muted)] border border-[var(--color-radar-border)]">
        {data}
      </span>
    ))}
  </div>

  <!-- Fila inferior: Fecha de revisión + Flecha interactiva -->
  <div class="flex items-center justify-between pt-3 border-t border-[var(--color-radar-border)] text-[var(--color-radar-text-muted)] text-[10px]">
    <span>Revisado: {dateStr}</span>
    
    <!-- Flecha discreta que se ilumina al hacer hover sobre la tarjeta entera -->
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" class="w-4 h-4 shrink-0 text-[var(--color-radar-text-muted)] group-hover:text-[var(--color-radar-accent)] group-hover:translate-x-1.5 transition-all duration-300">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
    </svg>
  </div>
</div>
