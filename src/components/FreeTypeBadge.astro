---
interface Props {
  freeType: string;
}

const { freeType } = Astro.props;

const typeColors: Record<string, string> = {
  "Gratis real": "bg-green-500/10 text-green-400 border-green-500/20",
  "Freemium decente": "bg-emerald-500/10 text-emerald-400 border-emerald-500/20",
  "Créditos gratis": "bg-yellow-500/10 text-yellow-400 border-yellow-500/20",
  "Trial útil": "bg-amber-500/10 text-amber-400 border-amber-500/20",
  "Open-source": "bg-blue-500/10 text-blue-400 border-blue-500/20",
  "Local": "bg-cyan-500/10 text-cyan-400 border-cyan-500/20",
  "Demo limitada": "bg-orange-500/10 text-orange-400 border-orange-500/20",
  "Requiere tarjeta": "bg-red-500/10 text-red-400 border-red-500/20",
  "Humo probable": "bg-gray-500/10 text-gray-400 border-gray-500/20",
};

const colorClass = typeColors[freeType] || "bg-[var(--color-radar-surface)] text-[var(--color-radar-text-muted)] border-[var(--color-radar-border)]";
---

<span class={`px-2.5 py-1 text-xs font-medium rounded-full border ${colorClass}`}>
  {freeType}
</span>
