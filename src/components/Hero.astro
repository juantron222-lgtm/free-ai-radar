---
const stats = [
  { value: "22", label: "Herramientas analizadas" },
  { value: "5", label: "Tipos de gratuidad" },
  { value: "0", label: "Herramientas con humo" },
];
---

<section class="relative overflow-hidden bg-gradient-to-b from-[var(--color-radar-surface)] to-[var(--color-radar-bg)] border-b border-[var(--color-radar-border)]">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-[var(--color-radar-accent)]/10 via-transparent to-transparent"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28 relative">
    <div class="max-w-3xl">
      <!-- Live indicator -->
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-radar-accent)]/10 border border-[var(--color-radar-accent)]/20 text-sm text-[var(--color-radar-accent-glow)] mb-6">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[var(--color-radar-green)] opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-[var(--color-radar-green)]"></span>
        </span>
        Radar activo &mdash; Detectando solo herramientas gratuitas
      </div>

      <h1 class="text-4xl md:text-6xl font-extrabold text-[var(--color-radar-text)] leading-tight mb-4">
        Free AI <span class="text-transparent bg-clip-text bg-gradient-to-r from-[var(--color-radar-accent-glow)] to-[var(--color-radar-purple)]">Radar</span>
      </h1>
      <p class="text-xl md:text-2xl text-[var(--color-radar-text-muted)] mb-3 font-medium">
        Novedades de IA gratis, filtradas y explicadas.
      </p>
      <p class="text-base text-[var(--color-radar-text-muted)] mb-8 max-w-xl leading-relaxed">
        Descubre herramientas, modelos, créditos gratuitos y recursos IA que realmente merecen la pena. Sin directorios infinitos, sin humo y sin perder horas comprobando si algo es gratis de verdad.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/tools?free_type=Gratis%20real" class="px-6 py-3 bg-[var(--color-radar-green)] text-black font-semibold rounded-xl hover:bg-green-400 transition-all hover:shadow-lg hover:shadow-green-500/25">
          ✅ Ver herramientas gratis
        </a>
        <a href="/tools?sort=newest" class="px-6 py-3 bg-[var(--color-radar-card)] border border-[var(--color-radar-border)] text-[var(--color-radar-text)] font-semibold rounded-xl hover:border-[var(--color-radar-accent)]/50 transition-all">
          🆕 Ver novedades recientes
        </a>
        <a href="/tools?no_card=true" class="px-6 py-3 text-[var(--color-radar-text-muted)] font-semibold rounded-xl hover:text-[var(--color-radar-text)] transition-colors hover:bg-[var(--color-radar-card)]">
          🚫 Filtrar sin tarjeta
        </a>
      </div>
    </div>

    <!-- Stats -->
    <div class="flex flex-wrap gap-8 mt-12">
      {stats.map((stat) => (
        <div>
          <div class="text-3xl font-bold text-[var(--color-radar-accent-glow)]">{stat.value}</div>
          <div class="text-sm text-[var(--color-radar-text-muted)]">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
