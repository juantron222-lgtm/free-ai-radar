---
interface Props {
  totalTools: number;
  openSourceCount: number;
  freeTypes: number;
}

const { totalTools, openSourceCount, freeTypes } = Astro.props;

const stats = [
  { value: String(totalTools), label: "Herramientas" },
  { value: String(freeTypes), label: "Tipos de gratuidad" },
  { value: String(openSourceCount), label: "Open-source / Local" },
];
---

<style>
  @keyframes radar-sweep {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
  .animate-radar-sweep {
    transform-origin: 150px 150px;
    animation: radar-sweep 12s linear infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-radar-sweep {
      animation: none;
    }
    .animate-pulse-slow {
      animation: none;
    }
  }
</style>

<section class="relative overflow-hidden bg-[#070A0F] py-20 md:py-28 border-b border-[var(--color-radar-border)]">
  <!-- Fondo decorativo sutil -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(116,247,192,0.03),transparent_40%)]"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
      <!-- Columna izquierda: Textos -->
      <div class="lg:col-span-7 space-y-8">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-md bg-[var(--color-radar-surface)] border border-[var(--color-radar-border)] text-xs font-semibold uppercase tracking-widest text-[var(--color-radar-accent)]">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full rounded-full bg-[var(--color-radar-accent)] opacity-75 animate-ping"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-[var(--color-radar-accent)]"></span>
          </span>
          Rastreo en tiempo real
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-[var(--color-radar-text)] leading-tight tracking-tight max-w-2xl">
          Encuentra la IA gratuita que realmente merece tu <span class="text-[var(--color-radar-accent)]">tiempo</span>.
        </h1>
        
        <p class="text-base sm:text-lg text-[var(--color-radar-text-muted)] max-w-xl leading-relaxed">
          Analizamos planes gratuitos, límites, tarjetas, marcas de agua y código abierto para separar las herramientas útiles del humo.
        </p>

        <!-- Botones de Acción -->
        <div class="flex flex-wrap gap-4 pt-2">
          <a
            href="/tools"
            class="px-6 py-3 bg-[var(--color-radar-accent)] hover:bg-[var(--color-radar-accent)]/80 text-[var(--color-radar-bg)] font-bold text-xs uppercase tracking-wider rounded-lg transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-radar-accent)] focus-visible:ring-offset-2 focus-visible:ring-offset-[#070A0F]"
          >
            Explorar radar
          </a>
          <a
            href="/tools?no_card=true"
            class="px-6 py-3 bg-[var(--color-radar-surface)] border border-[var(--color-radar-border)] hover:border-[var(--color-radar-accent)]/40 text-[var(--color-radar-text)] font-bold text-xs uppercase tracking-wider rounded-lg transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-radar-accent)] focus-visible:ring-offset-2 focus-visible:ring-offset-[#070A0F]"
          >
            Ver sin tarjeta
          </a>
        </div>

        <!-- Estadísticas -->
        <div class="grid grid-cols-3 gap-4 pt-8 border-t border-[var(--color-radar-border)] max-w-lg">
          {stats.map((stat) => (
            <div>
              <div class="text-2xl sm:text-3xl font-extrabold text-[var(--color-radar-text)] font-sora tracking-tight">{stat.value}</div>
              <div class="text-[10px] sm:text-xs font-semibold uppercase tracking-wider text-[var(--color-radar-text-muted)] mt-1">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Columna derecha: Visualización de Radar -->
      <div class="lg:col-span-5 flex justify-center lg:justify-end">
        <div class="relative w-[300px] h-[300px] bg-[var(--color-radar-surface)] rounded-full border border-[var(--color-radar-border)] flex items-center justify-center p-4">
          <!-- Cuadrícula de radar SVG -->
          <svg width="300" height="300" viewBox="0 0 300 300" fill="none" stroke="currentColor" aria-hidden="true" class="absolute inset-0 w-full h-full max-w-full max-h-full shrink-0 text-[var(--color-radar-border)]">
            <!-- Círculos concéntricos -->
            <circle cx="150" cy="150" r="135" stroke-width="1" />
            <circle cx="150" cy="150" r="95" stroke-width="1" stroke-dasharray="2 2" />
            <circle cx="150" cy="150" r="55" stroke-width="1" />
            
            <!-- Ejes -->
            <line x1="150" y1="15" x2="150" y2="285" stroke-width="1" opacity="0.5" />
            <line x1="15" y1="150" x2="285" y2="150" stroke-width="1" opacity="0.5" />
            
            <!-- Ángulos diagonales sutiles -->
            <line x1="55" y1="55" x2="245" y2="245" stroke-width="0.5" stroke-dasharray="3 3" opacity="0.3" />
            <line x1="245" y1="55" x2="55" y2="245" stroke-width="0.5" stroke-dasharray="3 3" opacity="0.3" />

            <!-- Línea de barrido animada -->
            <g class="animate-radar-sweep">
              <line x1="150" y1="150" x2="150" y2="15" stroke="var(--color-radar-accent)" stroke-width="1.5" opacity="0.8" />
              <!-- Haz de degradado del barrido (con formas de vectores para no meter dependencias) -->
              <path d="M150 150 L150 15 A135 135 0 0 1 190 22 Z" fill="url(#sweep-gradient)" opacity="0.15" />
            </g>

            <!-- Definición del gradiente en línea -->
            <defs>
              <linearGradient id="sweep-gradient" x1="150" y1="150" x2="180" y2="30" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="var(--color-radar-accent)" stop-opacity="0" />
                <stop offset="100%" stop-color="var(--color-radar-accent)" stop-opacity="1" />
              </linearGradient>
            </defs>
          </svg>

          <!-- Puntos detectados del radar con etiquetas descriptivas -->
          <!-- Punto 1: Open Source -->
          <div class="absolute top-[60px] left-[70px] flex items-center gap-1.5 animate-pulse-slow">
            <span class="w-2.5 h-2.5 rounded-full bg-[var(--color-radar-accent)] shadow-[0_0_8px_var(--color-radar-accent)]"></span>
            <span class="text-[9px] font-bold uppercase tracking-widest text-[var(--color-radar-text-muted)] bg-[var(--color-radar-bg)]/80 px-1 py-0.5 rounded border border-[var(--color-radar-border)]">Open Source</span>
          </div>

          <!-- Punto 2: Sin tarjeta -->
          <div class="absolute bottom-[80px] right-[60px] flex items-center gap-1.5 animate-pulse-slow" style="animation-delay: 1s;">
            <span class="w-2.5 h-2.5 rounded-full bg-[var(--color-radar-secondary)] shadow-[0_0_8px_var(--color-radar-secondary)]"></span>
            <span class="text-[9px] font-bold uppercase tracking-widest text-[var(--color-radar-text-muted)] bg-[var(--color-radar-bg)]/80 px-1 py-0.5 rounded border border-[var(--color-radar-border)]">Sin tarjeta</span>
          </div>

          <!-- Punto 3: Nuevo -->
          <div class="absolute top-[110px] right-[75px] flex items-center gap-1.5 animate-pulse-slow" style="animation-delay: 2s;">
            <span class="w-2.5 h-2.5 rounded-full bg-[var(--color-radar-accent)] shadow-[0_0_8px_var(--color-radar-accent)]"></span>
            <span class="text-[9px] font-bold uppercase tracking-widest text-[var(--color-radar-text-muted)] bg-[var(--color-radar-bg)]/80 px-1 py-0.5 rounded border border-[var(--color-radar-border)]">Nuevo</span>
          </div>
          
          <!-- Núcleo del radar -->
          <div class="w-4 h-4 rounded-full bg-[var(--color-radar-accent)]/20 border border-[var(--color-radar-accent)]/40 flex items-center justify-center relative">
            <div class="w-1.5 h-1.5 rounded-full bg-[var(--color-radar-accent)]"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
